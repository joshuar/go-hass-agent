{
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "dependencies": {
    "daisyui": "^5.5.19",
    "htmx.org": "^2.0.10",
    "hyperscript.org": "^0.9.91",
    "tailwindcss": "^4.3.0"
  },
  "description": " A Home Assistant, native app for desktop/laptop devices.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prettier-plugin-toml": "^2.0.6"
  },
  "license": "MIT",
  "name": "go-hass-agent",
  "scripts": {
    "build:js": "esbuild ./web/assets/scripts.js --bundle --minify --outdir=./web/content/",
    "build:dev:js": "esbuild ./web/assets/scripts.js --bundle --sourcemap --outdir=./web/content/",
    "build:css": "tailwindcss -i ./web/assets/styles.css -o ./web/content/styles.css --minify",
    "build:dev:css": "tailwindcss -i ./web/assets/styles.css -o ./web/content/styles.css --map"
  },
  "version": "0.0.0"
}
